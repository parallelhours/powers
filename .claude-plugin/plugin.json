{
  "name": "parallel-powers",
  "description": "Time tracking and session management powers for agentic development workflows. Track development time, log AI usage, and manage GitHub issues — all from within your coding agent.",
  "version": "1.4.5",
  "author": {
    "name": "parallelhours"
  },
  "homepage": "https://github.com/parallelhours/powers",
  "repository": "https://github.com/parallelhours/powers",
  "license": "MIT",
  "keywords": [
    "time-tracking",
    "session-management",
    "productivity",
    "kpi",
    "workflow"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/session_start_timer_check.py\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-lint.sh\"",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/prompt_counter.py\"",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/stop_token_logger.py\"",
            "async": false
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/subagent_stop_token_logger.py\"",
            "async": false
          }
        ]
      }
    ]
  }
}
